<http://www.ontologydesignpatterns.org/ont/fred/domain.owl#include_1> a <https://w3id.org/framester/data/propbank-3.4.0/RoleSet/include-91> ;
    ns1:include-91.subset <http://www.ontologydesignpatterns.org/ont/fred/domain.owl#conjunct_1> ;
    ns1:include-91.superset <http://www.ontologydesignpatterns.org/ont/fred/domain.owl#element_1> .

<http://www.ontologydesignpatterns.org/ont/fred/domain.owl#prolong_1> a <https://w3id.org/framester/data/propbank-3.4.0/RoleSet/prolong-01> ;
    ns6:precedes <http://www.ontologydesignpatterns.org/ont/fred/domain.owl#die_1> ;
    ns1:prolong-01.thing-getting-longer <http://www.ontologydesignpatterns.org/ont/fred/domain.owl#expose_1> .

<http://www.ontologydesignpatterns.org/ont/fred/domain.owl#significant_1> a <https://w3id.org/framester/data/propbank-3.4.0/RoleSet/significant-02> ;
