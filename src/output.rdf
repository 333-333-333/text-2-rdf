<http://www.ontologydesignpatterns.org/ont/fred/domain.owl#date-entity_1> a <http://www.ontologydesignpatterns.org/ont/fred/domain.owl#Date-entity> ;
    ns3:year 1867.0,
        1903.0,
        1911.0,
        1934.0 .

<http://www.ontologydesignpatterns.org/ont/fred/domain.owl#female_1> a <http://www.ontologydesignpatterns.org/ont/fred/domain.owl#Female> .

<http://www.ontologydesignpatterns.org/ont/fred/domain.owl#person_1> a ns6:Person ;
